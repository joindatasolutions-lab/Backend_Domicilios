APP_NAME=PetalOps Domicilios API
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://domiapp.joindata.com.co

DB_HOST=localhost
DB_PORT=5432
DB_NAME=petalops
DB_SCHEMA=petalops
DB_USER=postgres
DB_PASSWORD=postgres

SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

AWS_REGION=us-east-1
AWS_S3_BUCKET=petalops-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
CLOUDFRONT_DOMAIN=
AWS_S3_PUBLIC_BASE_URL=
# Usar solo si el bucket permite ACL publicas. Ejemplo: public-read
AWS_S3_OBJECT_ACL=
