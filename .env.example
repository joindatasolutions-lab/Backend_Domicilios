APP_NAME=PetalOps Domicilios API
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://domiapp.joindata.com.co
BACKEND_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

DB_HOST=localhost
DB_PORT=5432
DB_NAME=petalops
DB_SCHEMA=petalops
DB_USER=postgres
DB_PASSWORD=postgres
DB_CLOUD_SQL_INSTANCE=
DB_CONNECT_TIMEOUT=3
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30

SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

AWS_REGION=us-east-1
AWS_S3_BUCKET=petalops-assets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
CLOUDFRONT_DOMAIN=
AWS_S3_PUBLIC_BASE_URL=
# Usar solo si el bucket permite ACL publicas. Ejemplo: public-read
AWS_S3_OBJECT_ACL=
